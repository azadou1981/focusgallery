{% extends 'base.html.twig' %}

{% block title %}FocusGallery{% endblock %}

{% block body %}
<div class="container py-5">

    <h1 class="text-center display-4 fw-bold mb-2">Découvrez nos clichés</h1>
    <p class="text-center text-muted mb-5">Explorez notre collection de photographies</p>

    <!-- Catégories (style pill) -->
    <div class="d-flex justify-content-center flex-wrap gap-2 mb-5">
        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary rounded-pill px-4">Tous</a>
        
        {% for category in categories %}
            <a href="#" 
               class="btn rounded-pill px-4"
               style="background-color: {{ category.color }}; color: white;">
                {{ category.name }}
            </a>
        {% endfor %}
    </div>

    <!-- Grille Photos -->
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for photo in photos %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                    <img src="{{ vich_uploader_asset(photo, 'imageFile') }}" 
                         class="card-img-top"
                         alt="{{ photo.title }}"
                         style="height: 280px; object-fit: cover;">
                    
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">{{ photo.title }}</h5>
                        
                        <span class="badge rounded-pill px-3 py-2 mb-4" 
                              style="background-color: {{ photo.category.color }}; color: white;">
                            {{ photo.category.name }}
                        </span>
                        
                        <a href="{{ path('app_photo_show', {id: photo.id}) }}" 
                           class="btn btn-dark rounded-pill w-100">
                            Voir
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}